rules_version = '2';
/**
 * Firestore Security Rules – Japam
 *
 * Most data access goes through the API (Firebase Admin SDK bypasses these rules).
 * Client directly reads only config/pricing and config/admins for fallback when API is unavailable.
 * All other collections: deny direct client access.
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // Config: pricing – read for authenticated users (pricing fallback). Write only for admins.
    match /config/pricing {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/config/admins)
        && (
          ('uids' in get(/databases/$(database)/documents/config/admins).data
            && request.auth.uid in get(/databases/$(database)/documents/config/admins).data.uids)
          || ('uid' in get(/databases/$(database)/documents/config/admins).data
            && request.auth.uid == get(/databases/$(database)/documents/config/admins).data.uid)
        );
    }

    // Config: admins – read for authenticated (admin check). Never allow client write.
    match /config/admins {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // All other paths: deny direct client access. Data is accessed via API only.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
