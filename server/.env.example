# Admin login for /admin page (server-only; never exposed to frontend)
ADMIN_ID=your-admin-id
ADMIN_PASSWORD=your-admin-password

# Secret for signing admin session tokens (use a long random string in production)
ADMIN_SECRET=change-me-to-a-random-secret

# Optional: same as root if you run server from here
# FIREBASE_SERVICE_ACCOUNT_JSON=
# Cashfree (for create-order, verify-unlock, donate-order, verify-donate)
# CASHFREE_APP_ID=
# CASHFREE_SECRET=
