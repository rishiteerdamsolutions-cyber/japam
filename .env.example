# Firebase - required for Google Sign-In
# Get these from https://console.firebase.google.com/ → Project Settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin (required for priest login, user unlock, Apavarga APIs).
# Get from Firebase Console → Project Settings → Service accounts → Generate new private key.
# Paste the entire JSON as a single line or escaped string.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Cashfree (Pro unlock / Offer Dakshina). Get from https://merchant.cashfree.com/merchants/pg/developers/api-keys
# App ID and Secret go only on server (api handlers). Never expose secret in frontend.
CASHFREE_APP_ID=
CASHFREE_SECRET=
# Use CASHFREE_ENV=sandbox for testing; omit or production for live
# CASHFREE_ENV=sandbox
# Backend API URL. For local dev use http://localhost:3001 (run server in server/). On Vercel leave empty to use same-origin /api.
VITE_API_URL=http://localhost:3001

# Apavarga community app URL (must be the full URL where the community app is deployed).
# When users tap "Log in" in Japam they are sent here with SSO. For local dev use http://localhost:5174.
# In production set to your deployed Apavarga URL (e.g. https://apavarga.yourdomain.com or same-origin path).
VITE_APAVARGA_URL=http://localhost:5174

# Sentry error tracking. Get DSN from https://sentry.io → Project → Client Keys (DSN). Add in Vercel for production.
# VITE_SENTRY_DSN=
