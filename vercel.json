{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {"source": "/api/:path*", "destination": "/api/proxy?path=:path*"},
    {"source": "/apavarga", "destination": "/apavarga/index.html"},
    {"source": "/apavarga/:path*", "destination": "/apavarga/index.html"},
    {"source": "/((?!api/)(?!apavarga).*)", "destination": "/index.html"}
  ],
  "crons": [
    {"path": "/api/apavarga/cleanup", "schedule": "0 0 * * *"},
    {"path": "/api/cron/refresh-active-users", "schedule": "30 21 * * *"},
    {"path": "/api/cron/update-maha-yagna-counters", "schedule": "0 0 * * *"}
  ]
}
